+/// Race test (Finding 5): explicit `release_spawned_thread` followed by
+/// `retire_spawned_thread` on the same thread must not double-decrement
+/// the shared spawn count. After release the metadata is gone, so retire
+/// is a no-op rather than a second decrement.
+#[test]
+fn retire_after_release_does_not_double_decrement() {
+    let registry = Arc::new(AgentRegistry::default());
+    let thread_id = ThreadId::new();
+    let reservation = registry.reserve_spawn_slot(Some(1)).expect("reserve slot");
+    reservation.commit(agent_metadata(thread_id));
+
+    registry.release_spawned_thread(thread_id);
+    // Idempotent: retire after release has no effect on the shared count.
+    registry.retire_spawned_thread(thread_id, AgentStatus::Completed(Some("done".to_string())));
+
+    let reservation = registry
+        .reserve_spawn_slot(Some(1))
+        .expect("released slot should be available");
+    drop(reservation);
+}
+
+/// Race test (Finding 5): a second `retire_spawned_thread` for the same
+/// thread (e.g., the V1 completion watcher and V2 notification path both
+/// firing for the same finalized agent) must not double-decrement. The
+/// first retire transitions `Active -> Retired { .. }`; the second sees
+/// `slot_state.is_active() == false` and leaves the count alone.
+#[test]
+fn retire_is_idempotent_for_repeated_calls() {
+    let registry = Arc::new(AgentRegistry::default());
+    let thread_id = ThreadId::new();
+    let reservation = registry.reserve_spawn_slot(Some(1)).expect("reserve slot");
+    reservation.commit(agent_metadata(thread_id));
+
+    registry.retire_spawned_thread(thread_id, AgentStatus::Completed(Some("first".to_string())));
+    // Second retirement with a different status. Must not double-decrement.
+    registry.retire_spawned_thread(thread_id, AgentStatus::Errored("second".to_string()));
+
+    // Slot is freed exactly once: capacity 1 still has room for one new agent.
+    let reservation = registry
+        .reserve_spawn_slot(Some(1))
+        .expect("retired slot should remain released");
+    drop(reservation);
+
+    // The cached status is the latest one written.
+    assert_eq!(
+        registry.cached_status_for_thread(thread_id),
+        Some(AgentStatus::Errored("second".to_string()))
+    );
+}
+
+/// Race test (Finding 5): retire then explicit release. The first retire
+/// already decremented the shared count and flipped the slot state to
+/// `Retired`. Releasing the metadata afterwards must not decrement again.
+#[test]
+fn release_after_retire_does_not_double_decrement() {
+    let registry = Arc::new(AgentRegistry::default());
+    let thread_id = ThreadId::new();
+    let reservation = registry.reserve_spawn_slot(Some(1)).expect("reserve slot");
+    reservation.commit(agent_metadata(thread_id));
+
+    registry.retire_spawned_thread(thread_id, AgentStatus::Completed(Some("done".to_string())));
+    // Now explicitly release the metadata too. The retire already decremented;
+    // release must observe `slot_state == Retired` (not Active) and skip the
+    // decrement.
+    registry.release_spawned_thread(thread_id);
+
+    // Capacity 1 still has room for one new agent. If release double-decremented
+    // here, the count would go to -1 and the next reserve would behave oddly.
+    let reservation = registry
+        .reserve_spawn_slot(Some(1))
+        .expect("slot should remain released after retire+release");
+    drop(reservation);
+}
