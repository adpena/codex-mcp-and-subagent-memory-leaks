+    pub(crate) fn retire_spawned_thread(&self, thread_id: ThreadId, status: AgentStatus) {
+        let released_slot = {
+            let mut active_agents = self
+                .active_agents
+                .lock()
+                .unwrap_or_else(std::sync::PoisonError::into_inner);
+            let Some(metadata) = active_agents
+                .agent_tree
+                .values_mut()
+                .find(|metadata| metadata.agent_id == Some(thread_id))
+            else {
+                return;
+            };
+            metadata.last_status = Some(status);
+            let released_slot = metadata.slot_active;
+            metadata.slot_active = false;
+            released_slot
+        };
+        if released_slot {
+            self.total_count.fetch_sub(1, Ordering::AcqRel);
+        }
+    }
