+    /// Retire a spawned subagent that has reached a terminal status (`Completed`
+    /// or `Errored`) without explicit shutdown. Releases its slot in the
+    /// registry, caches its final status for `wait_agent` / `list_agents` /
+    /// `resume_agent` UX, and explicitly drives the session through its
+    /// `handlers::shutdown` path so post-#19753 MCP teardown fires.
+    ///
+    /// Visible to the session module so the `MultiAgentV2` notification path
+    /// can call this directly, since V2 does not start the V1 completion
+    /// watcher in `agent::control::maybe_start_completion_watcher`.
+    pub(crate) async fn retire_finalized_agent(
+        &self,
+        agent_id: ThreadId,
+        status: AgentStatus,
+    ) -> CodexResult<()> {
+        let state = self.upgrade()?;
+        let mut flush_result = Ok(());
+        if let Ok(thread) = state.get_thread(agent_id).await {
+            thread.codex.session.ensure_rollout_materialized().await;
+            flush_result = thread.codex.session.flush_rollout().await;
+            // Drive the session through its own `handlers::shutdown` path so
+            // post-#19753 `mcp_connection_manager.begin_shutdown()` fires
+            // deterministically. Without this, MCP-server teardown for a
+            // finalized subagent would depend on the last `Arc<CodexThread>`
+            // being dropped so the submission channel closes — plausible but
+            // not deterministic if any caller still holds a reference.
+            //
+            // `Op::Shutdown` is tolerant of a closed channel (returns an
+            // error we log and ignore) and of repeated invocation: if the
+            // session is already in `Shutdown` we skip the send entirely.
+            if !matches!(thread.agent_status().await, AgentStatus::Shutdown)
+                && let Err(err) = state.send_op(agent_id, Op::Shutdown {}).await
+            {
+                warn!(
+                    error = ?err,
+                    "retire_finalized_agent: explicit shutdown send for {agent_id} returned",
+                );
+            }
+            let _ = state.remove_thread(&agent_id).await;
+        }
+        self.state.retire_spawned_thread(agent_id, status.clone());
+        tracing::debug!(
+            agent_id = %agent_id,
+            status = ?status,
+            "retire_finalized_agent: slot retired",
+        );
+        flush_result.map_err(Into::into)
+    }
