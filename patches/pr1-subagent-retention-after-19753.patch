+#[test]
+fn retire_releases_slot_and_preserves_cached_status() {
+    let registry = Arc::new(AgentRegistry::default());
+    let thread_id = ThreadId::new();
+    let reservation = registry.reserve_spawn_slot(Some(1)).expect("reserve slot");
+    reservation.commit(agent_metadata(thread_id));
+
+    registry.retire_spawned_thread(thread_id, AgentStatus::Completed(Some("done".to_string())));
+
+    let reservation = registry
+        .reserve_spawn_slot(Some(1))
+        .expect("slot should be released after retire");
+    drop(reservation);
+
+    assert_eq!(
+        registry.cached_status_for_thread(thread_id),
+        Some(AgentStatus::Completed(Some("done".to_string())))
+    );
+}
+
+#[test]
+fn clear_for_root_shutdown_releases_all_spawned_slots() {
+    let registry = Arc::new(AgentRegistry::default());
+    let first_id = ThreadId::new();
+    let second_id = ThreadId::new();
+
+    let first = registry.reserve_spawn_slot(Some(2)).expect("reserve first");
+    first.commit(agent_metadata(first_id));
+    let second = registry
+        .reserve_spawn_slot(Some(2))
+        .expect("reserve second");
+    second.commit(agent_metadata(second_id));
+
+    let err = match registry.reserve_spawn_slot(Some(2)) {
+        Ok(_) => panic!("limit should be enforced"),
+        Err(err) => err,
+    };
+    assert!(matches!(
+        err,
+        CodexErr::AgentLimitReached { max_threads: 2 }
+    ));
+
+    registry.clear_for_root_shutdown();
+
+    let reservation = registry
+        .reserve_spawn_slot(Some(2))
+        .expect("slots should be released after root shutdown clear");
+    drop(reservation);
+}
