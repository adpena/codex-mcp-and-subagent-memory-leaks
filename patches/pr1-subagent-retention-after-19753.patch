+    pub(crate) fn retire_spawned_thread(&self, thread_id: ThreadId, status: AgentStatus) {
+        let released_slot = {
+            let mut active_agents = self
+                .active_agents
+                .lock()
+                .unwrap_or_else(std::sync::PoisonError::into_inner);
+            let Some(metadata) = active_agents
+                .agent_tree
+                .values_mut()
+                .find(|metadata| metadata.agent_id == Some(thread_id))
+            else {
+                return;
+            };
+            // Idempotency: a second retirement (or one racing with explicit
+            // shutdown) must not double-decrement the shared count.
+            let was_active = metadata.slot_state.is_active();
+            metadata.slot_state = SlotState::Retired {
+                last_status: status,
+            };
+            was_active
