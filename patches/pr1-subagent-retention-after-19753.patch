+/// Lifecycle state of a registry entry's slot accounting.
+///
+/// Three explicit cases, in place of the earlier `slot_active: bool` plus
+/// `last_status: Option<AgentStatus>` pair:
+///
+/// - `NotTracked`: the entry never consumed a spawn slot. This is the root
+///   thread, registered for nickname/path indexing but never counted against
+///   `agents.max_threads`.
+/// - `Active`: the entry consumes a spawn slot right now and should count
+///   against `agents.max_threads`.
+/// - `Retired { last_status }`: the entry's spawned thread reached a terminal
+///   state (`Completed` / `Errored`), released its slot, and is preserved for
+///   `wait_agent` / `list_agents` / `resume_agent` UX. It does not count
+///   against `agents.max_threads`.
+///
+/// `register_spawned_thread` always commits in `Active`. `retire_spawned_thread`
+/// transitions `Active -> Retired { .. }`, decrementing the shared count once.
+/// `release_spawned_thread` only decrements when removing an `Active` entry.
+#[derive(Clone, Debug, Default, PartialEq)]
+pub(crate) enum SlotState {
+    #[default]
+    NotTracked,
+    Active,
+    Retired {
+        last_status: AgentStatus,
+    },
+}
+
+impl SlotState {
+    pub(crate) fn is_active(&self) -> bool {
+        matches!(self, SlotState::Active)
+    }
+
+    pub(crate) fn last_status(&self) -> Option<&AgentStatus> {
+        match self {
+            SlotState::Retired { last_status } => Some(last_status),
+            SlotState::Active | SlotState::NotTracked => None,
+        }
+    }
+}
+
